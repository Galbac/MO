    1: from datetime import datetime
       
    1: from sqlalchemy import DateTime, func
    1: from sqlalchemy.orm import Mapped, mapped_column
       
       
    2: class TimestampMixin:
    1:     created_at: Mapped[datetime] = mapped_column(DateTime(timezone=True), server_default=func.now())
    2:     updated_at: Mapped[datetime] = mapped_column(
    1:         DateTime(timezone=True),
    1:         server_default=func.now(),
    1:         onupdate=func.now(),
           )
