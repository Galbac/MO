    1: from datetime import datetime
       
    1: from pydantic import BaseModel, Field
       
    1: from source.schemas.pydantic.news import NewsArticleSummary
       
       
    2: class MatchSummary(BaseModel):
    1:     id: int
    1:     slug: str
    1:     status: str
    1:     scheduled_at: datetime
