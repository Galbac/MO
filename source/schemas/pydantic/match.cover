    2: class MatchEventItem(BaseModel):
    1:     id: int
    1:     event_type: str
    1:     set_number: int | None = None
    1:     game_number: int | None = None
    1:     player_id: int | None = None
    1:     payload_json: dict = Field(default_factory=dict)
    1:     created_at: datetime
       
       
    2: class MatchPreview(BaseModel):
    1:     h2h_summary: dict
    1:     player1_form: list[str]
    1:     player2_form: list[str]
    1:     notes: list[str]
       
       
    2: class MatchDetail(MatchSummary):
    1:     best_of_sets: int
    1:     winner_id: int | None = None
    1:     score: MatchScore
    1:     sets: list[MatchSetItem] = Field(default_factory=list)
    1:     stats: MatchStats | None = None
    1:     timeline: list[MatchEventItem] = Field(default_factory=list)
    1:     h2h: dict = Field(default_factory=dict)
    1:     related_news: list[NewsArticleSummary] = Field(default_factory=list)
       
       
    2: class MatchStatusUpdateRequest(BaseModel):
    1:     status: str
       
       
    2: class MatchScoreUpdateRequest(BaseModel):
    1:     score_summary: str
    1:     sets: list[MatchSetItem] = Field(default_factory=list)
       
       
    2: class MatchStatsUpdateRequest(BaseModel):
    1:     stats: MatchStats
       
       
    2: class MatchEventCreateRequest(BaseModel):
    1:     event_type: str
