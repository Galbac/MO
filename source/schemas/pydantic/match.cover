    1:     score_summary: str | None = None
       
       
    2: class MatchScore(BaseModel):
    1:     sets: list[str] = Field(default_factory=list)
    1:     current_game: str | None = None
    1:     serving_player_id: int | None = None
       
       
    2: class MatchSetItem(BaseModel):
    1:     set_number: int
    1:     player1_games: int
    1:     player2_games: int
    1:     tiebreak_player1_points: int | None = None
    1:     tiebreak_player2_points: int | None = None
    1:     is_finished: bool = True
       
       
    2: class MatchStats(BaseModel):
    1:     player1_aces: int = 0
    1:     player2_aces: int = 0
    1:     player1_double_faults: int = 0
    1:     player2_double_faults: int = 0
    1:     player1_first_serve_pct: float = 0
    1:     player2_first_serve_pct: float = 0
