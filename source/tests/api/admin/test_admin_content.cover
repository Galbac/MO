    1: from fastapi import status
       
    1: from source.config.settings import settings
       
       
    1: async def test_admin_players_crud_flow(async_client, admin_auth_headers) -> None:
    2:     create_response = await async_client.post(
    1:         f"{settings.api.prefix}{settings.api.v1.prefix}/admin/players",
    1:         json={"first_name": "Carlos", "last_name": "Alcaraz", "full_name": "Carlos Alcaraz", "slug": "carlos-alcaraz", "country_code": "ESP", "current_rank": 3},
    1:         headers=admin_auth_headers,
           )
    1:     assert create_response.status_code == status.HTTP_200_OK
    1:     player_id = create_response.json()["data"]["id"]
       
    2:     patch_response = await async_client.patch(
    1:         f"{settings.api.prefix}{settings.api.v1.prefix}/admin/players/{player_id}",
    1:         json={"current_points": 7800, "status": "active"},
    1:         headers=admin_auth_headers,
           )
    1:     assert patch_response.status_code == status.HTTP_200_OK
    1:     assert patch_response.json()["data"]["current_points"] == 7800
       
    1:     delete_response = await async_client.delete(f"{settings.api.prefix}{settings.api.v1.prefix}/admin/players/{player_id}", headers=admin_auth_headers)
    1:     assert delete_response.status_code == status.HTTP_200_OK
    1:     assert delete_response.json()["data"]["message"] == "Player deleted"
       
       
