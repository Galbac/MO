    1: from fastapi import status
       
    1: from source.config.settings import settings
       
       
    1: async def test_admin_media_returns_library(async_client, admin_auth_headers) -> None:
    2:     upload_response = await async_client.post(
    1:         f"{settings.api.prefix}{settings.api.v1.prefix}/admin/media/upload",
    1:         json={"filename": "note.txt", "content_type": "text/plain", "content": "preview"},
    1:         headers=admin_auth_headers,
           )
    1:     assert upload_response.status_code == status.HTTP_201_CREATED
       
    1:     response = await async_client.get(f"{settings.api.prefix}{settings.api.v1.prefix}/admin/media", headers=admin_auth_headers)
       
    1:     assert response.status_code == status.HTTP_200_OK
    1:     payload = response.json()
    1:     assert payload["success"] is True
    1:     assert payload["data"][0]["filename"] == "note.txt"
       
       
    1: async def test_admin_notifications_returns_history(async_client, admin_auth_headers) -> None:
    1:     response = await async_client.get(f"{settings.api.prefix}{settings.api.v1.prefix}/admin/notifications", headers=admin_auth_headers)
       
    1:     assert response.status_code == status.HTTP_200_OK
    1:     payload = response.json()
    1:     assert payload["success"] is True
    1:     assert payload["data"][0]["status"] in {"sent", "queued"}
