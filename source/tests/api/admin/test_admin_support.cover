    1: from fastapi import status
       
    1: from source.config.settings import settings
       
       
    1: async def test_admin_settings_persist(async_client, admin_auth_headers) -> None:
    2:     patch_response = await async_client.patch(
    1:         f"{settings.api.prefix}{settings.api.v1.prefix}/admin/settings",
    1:         json={"seo_title": "Portal SEO", "support_email": "support@example.com"},
    1:         headers=admin_auth_headers,
           )
    1:     assert patch_response.status_code == status.HTTP_200_OK
    1:     assert patch_response.json()["data"]["seo_title"] == "Portal SEO"
       
    1:     get_response = await async_client.get(f"{settings.api.prefix}{settings.api.v1.prefix}/admin/settings", headers=admin_auth_headers)
    1:     assert get_response.status_code == status.HTTP_200_OK
    1:     assert get_response.json()["data"]["support_email"] == "support@example.com"
       
       
    1: async def test_admin_taxonomy_crud(async_client, admin_auth_headers) -> None:
    2:     create_category = await async_client.post(
    1:         f"{settings.api.prefix}{settings.api.v1.prefix}/admin/news-categories",
    1:         json={"name": "Features", "slug": "features"},
    1:         headers=admin_auth_headers,
           )
    1:     assert create_category.status_code == status.HTTP_200_OK
       
    1:     categories_response = await async_client.get(f"{settings.api.prefix}{settings.api.v1.prefix}/admin/news-categories", headers=admin_auth_headers)
    3:     category_id = next(item["id"] for item in categories_response.json()["data"] if item["slug"] == "features")
       
    2:     update_category = await async_client.patch(
    1:         f"{settings.api.prefix}{settings.api.v1.prefix}/admin/news-categories/{category_id}",
    1:         json={"name": "Deep Features", "slug": "deep-features"},
    1:         headers=admin_auth_headers,
           )
    1:     assert update_category.status_code == status.HTTP_200_OK
       
    2:     create_tag = await async_client.post(
