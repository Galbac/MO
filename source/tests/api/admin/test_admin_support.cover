    1:         json={"name": "Live Blog", "slug": "live-blog"},
    1:         headers=admin_auth_headers,
           )
    1:     assert create_tag.status_code == status.HTTP_200_OK
       
    1:     tags_response = await async_client.get(f"{settings.api.prefix}{settings.api.v1.prefix}/admin/tags", headers=admin_auth_headers)
    4:     tag_id = next(item["id"] for item in tags_response.json()["data"] if item["slug"] == "live-blog")
       
    1:     delete_tag = await async_client.delete(f"{settings.api.prefix}{settings.api.v1.prefix}/admin/tags/{tag_id}", headers=admin_auth_headers)
    1:     assert delete_tag.status_code == status.HTTP_200_OK
       
       
