    1: async def test_admin_rankings_provider_import_updates_current_snapshot(async_client, admin_auth_headers) -> None:
    2:     import_response = await async_client.post(
    1:         f"{settings.api.prefix}{settings.api.v1.prefix}/admin/rankings/import",
    1:         json={
    1:             'provider': 'rankings-provider',
    1:             'provider_payload': {
    1:                 'ranking_type': 'atp',
    1:                 'ranking_date': '2026-03-10',
    1:                 'entries': [
    1:                     {'position': 1, 'player_name': 'Jannik Sinner', 'country_code': 'IT', 'points': 9100},
    1:                     {'position': 2, 'player_name': 'Novak Djokovic', 'country_code': 'RS', 'points': 8700},
                       ],
                   },
               },
    1:         headers=admin_auth_headers,
           )
    1:     assert import_response.status_code == status.HTTP_200_OK
       
    1:     rankings_response = await async_client.get(f"{settings.api.prefix}{settings.api.v1.prefix}/rankings/current?ranking_type=atp")
    1:     assert rankings_response.status_code == status.HTTP_200_OK
    1:     assert rankings_response.json()['data'][0]['player_name'] == 'Jannik Sinner'
    1:     assert rankings_response.json()['data'][0]['ranking_date'] == '2026-03-10'
