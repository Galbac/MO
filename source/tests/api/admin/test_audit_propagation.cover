    1: from fastapi import status
       
    1: from source.config.settings import settings
       
       
    1: async def test_user_profile_update_creates_audit_log(async_client, user_auth_headers, admin_auth_headers) -> None:
    2:     response = await async_client.patch(
    1:         f"{settings.api.prefix}{settings.api.v1.prefix}/users/me",
    1:         json={"first_name": "Audited"},
    1:         headers=user_auth_headers,
           )
    1:     assert response.status_code == status.HTTP_200_OK
       
    1:     audit_response = await async_client.get(f"{settings.api.prefix}{settings.api.v1.prefix}/admin/audit-logs", headers=admin_auth_headers)
    1:     assert audit_response.status_code == status.HTTP_200_OK
    2:     assert any(item["action"] == "user.update_profile" for item in audit_response.json()["data"])
       
       
    1: async def test_admin_content_update_creates_audit_log(async_client, admin_auth_headers) -> None:
    2:     create_response = await async_client.post(
    1:         f"{settings.api.prefix}{settings.api.v1.prefix}/admin/players",
    1:         json={"first_name": "Audit", "last_name": "Player", "full_name": "Audit Player", "slug": "audit-player", "country_code": "ESP"},
    1:         headers=admin_auth_headers,
           )
    1:     assert create_response.status_code == status.HTTP_200_OK
    1:     player_id = create_response.json()["data"]["id"]
       
    1:     audit_response = await async_client.get(f"{settings.api.prefix}{settings.api.v1.prefix}/admin/audit-logs", headers=admin_auth_headers)
    1:     assert audit_response.status_code == status.HTTP_200_OK
    2:     assert any(item["action"] == "player.create" and item["entity_id"] == player_id for item in audit_response.json()["data"])
       
       
    1: async def test_admin_user_update_creates_audit_log(async_client, admin_auth_headers) -> None:
    2:     response = await async_client.patch(
    1:         f"{settings.api.prefix}{settings.api.v1.prefix}/admin/users/2",
    1:         json={"status": "blocked"},
    1:         headers=admin_auth_headers,
           )
    1:     assert response.status_code == status.HTTP_200_OK
       
    1:     audit_response = await async_client.get(f"{settings.api.prefix}{settings.api.v1.prefix}/admin/audit-logs", headers=admin_auth_headers)
    1:     assert audit_response.status_code == status.HTTP_200_OK
    2:     assert any(item["action"] == "admin.user.update" and item["entity_id"] == 2 for item in audit_response.json()["data"])
