    1: from fastapi import status
       
    1: from source.config.settings import settings
       
       
    1: async def test_auth_me_returns_success(async_client, user_auth_headers) -> None:
    1:     response = await async_client.get(f"{settings.api.prefix}{settings.api.v1.prefix}/auth/me", headers=user_auth_headers)
       
    1:     assert response.status_code == status.HTTP_200_OK
    1:     payload = response.json()
    1:     assert payload["success"] is True
    1:     assert payload["data"]["username"] == "demo_user"
       
       
    1: async def test_register_creates_user_and_returns_tokens(async_client) -> None:
    2:     response = await async_client.post(
    1:         f"{settings.api.prefix}{settings.api.v1.prefix}/auth/register",
    1:         json={
    1:             "email": "new-user@example.com",
    1:             "username": "new_user",
    1:             "password": "StrongPass123",
    1:             "locale": "en",
    1:             "timezone": "UTC",
               },
           )
       
    1:     assert response.status_code == status.HTTP_201_CREATED
    1:     payload = response.json()
    1:     assert payload["success"] is True
    1:     assert payload["data"]["user"]["email"] == "new-user@example.com"
    1:     assert payload["data"]["access_token"]
       
       
    1: async def test_login_returns_db_backed_user(async_client) -> None:
    2:     response = await async_client.post(
    1:         f"{settings.api.prefix}{settings.api.v1.prefix}/auth/login",
    1:         json={"email_or_username": "demo_user", "password": "UserPass123"},
           )
       
    1:     assert response.status_code == status.HTTP_200_OK
    1:     payload = response.json()
    1:     assert payload["data"]["user"]["username"] == "demo_user"
    1:     assert payload["data"]["refresh_token"]
       
       
    1: async def test_refresh_token_rotation_invalidates_old_refresh(async_client) -> None:
    2:     login_response = await async_client.post(
    1:         f"{settings.api.prefix}{settings.api.v1.prefix}/auth/login",
    1:         json={"email_or_username": "demo_user", "password": "UserPass123"},
           )
    1:     assert login_response.status_code == status.HTTP_200_OK
    1:     refresh_token = login_response.json()["data"]["refresh_token"]
       
    2:     refresh_response = await async_client.post(
    1:         f"{settings.api.prefix}{settings.api.v1.prefix}/auth/refresh",
    1:         json={"refresh_token": refresh_token},
           )
    1:     assert refresh_response.status_code == status.HTTP_200_OK
       
    2:     reused_response = await async_client.post(
    1:         f"{settings.api.prefix}{settings.api.v1.prefix}/auth/refresh",
    1:         json={"refresh_token": refresh_token},
           )
    1:     assert reused_response.status_code == status.HTTP_401_UNAUTHORIZED
       
       
    1: async def test_login_bruteforce_is_rate_limited(async_client) -> None:
    6:     for _ in range(5):
   10:         response = await async_client.post(
    5:             f"{settings.api.prefix}{settings.api.v1.prefix}/auth/login",
    5:             json={"email_or_username": "demo_user", "password": "wrong-password"},
               )
    5:         assert response.status_code in {status.HTTP_401_UNAUTHORIZED, status.HTTP_429_TOO_MANY_REQUESTS}
       
    2:     locked_response = await async_client.post(
    1:         f"{settings.api.prefix}{settings.api.v1.prefix}/auth/login",
    1:         json={"email_or_username": "demo_user", "password": "UserPass123"},
           )
    1:     assert locked_response.status_code == status.HTTP_429_TOO_MANY_REQUESTS
