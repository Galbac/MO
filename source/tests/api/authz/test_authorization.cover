    1: from fastapi import status
       
    1: from source.config.settings import settings
       
       
    1: async def test_user_profile_requires_auth(async_client) -> None:
    1:     response = await async_client.get(f"{settings.api.prefix}{settings.api.v1.prefix}/users/me")
    1:     assert response.status_code == status.HTTP_401_UNAUTHORIZED
       
       
    1: async def test_admin_endpoint_forbids_regular_user(async_client, user_auth_headers) -> None:
    1:     response = await async_client.get(f"{settings.api.prefix}{settings.api.v1.prefix}/admin/users", headers=user_auth_headers)
    1:     assert response.status_code == status.HTTP_403_FORBIDDEN
       
       
    1: async def test_admin_endpoint_allows_admin(async_client, admin_auth_headers) -> None:
    1:     response = await async_client.get(f"{settings.api.prefix}{settings.api.v1.prefix}/admin/users", headers=admin_auth_headers)
    1:     assert response.status_code == status.HTTP_200_OK
       
       
    1: async def test_editor_access_matrix(async_client, editor_auth_headers) -> None:
    1:     news_response = await async_client.get(f"{settings.api.prefix}{settings.api.v1.prefix}/admin/news", headers=editor_auth_headers)
    1:     media_response = await async_client.get(f"{settings.api.prefix}{settings.api.v1.prefix}/admin/media", headers=editor_auth_headers)
    1:     users_response = await async_client.get(f"{settings.api.prefix}{settings.api.v1.prefix}/admin/users", headers=editor_auth_headers)
       
    1:     assert news_response.status_code == status.HTTP_200_OK
    1:     assert media_response.status_code == status.HTTP_200_OK
    1:     assert users_response.status_code == status.HTTP_403_FORBIDDEN
       
       
    1: async def test_operator_access_matrix(async_client, operator_auth_headers) -> None:
    1:     matches_response = await async_client.get(f"{settings.api.prefix}{settings.api.v1.prefix}/admin/matches", headers=operator_auth_headers)
    1:     news_response = await async_client.get(f"{settings.api.prefix}{settings.api.v1.prefix}/admin/news", headers=operator_auth_headers)
    1:     users_response = await async_client.get(f"{settings.api.prefix}{settings.api.v1.prefix}/admin/users", headers=operator_auth_headers)
       
    1:     assert matches_response.status_code == status.HTTP_200_OK
    1:     assert news_response.status_code == status.HTTP_403_FORBIDDEN
    1:     assert users_response.status_code == status.HTTP_403_FORBIDDEN
       
       
    1: async def test_editor_cannot_finalize_match(async_client, editor_auth_headers) -> None:
    1:     response = await async_client.post(f"{settings.api.prefix}{settings.api.v1.prefix}/admin/matches/2/finalize", headers=editor_auth_headers)
    1:     assert response.status_code == status.HTTP_403_FORBIDDEN
       
       
    1: async def test_operator_can_update_match_score(async_client, operator_auth_headers) -> None:
    2:     response = await async_client.patch(
    1:         f"{settings.api.prefix}{settings.api.v1.prefix}/admin/matches/2/score",
    1:         headers=operator_auth_headers,
    1:         json={"score_summary": "6-4 4-6 5-4", "sets": []},
           )
    1:     assert response.status_code == status.HTTP_200_OK
       
       
    1: async def test_operator_cannot_manage_media(async_client, operator_auth_headers) -> None:
    1:     response = await async_client.get(f"{settings.api.prefix}{settings.api.v1.prefix}/admin/media", headers=operator_auth_headers)
    1:     assert response.status_code == status.HTTP_403_FORBIDDEN
       
       
    1: async def test_malformed_bearer_token_cannot_access_admin(async_client) -> None:
    2:     response = await async_client.get(
    1:         f"{settings.api.prefix}{settings.api.v1.prefix}/admin/users",
    1:         headers={"Authorization": "Bearer definitely.invalid.token"},
           )
    1:     assert response.status_code == status.HTTP_401_UNAUTHORIZED
