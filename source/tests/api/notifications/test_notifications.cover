    1: from fastapi import status
       
    1: from source.config.settings import settings
       
       
    1: async def test_notifications_endpoints_use_db_backed_data(async_client, user_auth_headers) -> None:
    1:     list_response = await async_client.get(f"{settings.api.prefix}{settings.api.v1.prefix}/notifications", headers=user_auth_headers)
    1:     assert list_response.status_code == status.HTTP_200_OK
    1:     assert len(list_response.json()["data"]) >= 1
       
    1:     unread_response = await async_client.get(f"{settings.api.prefix}{settings.api.v1.prefix}/notifications/unread-count", headers=user_auth_headers)
    1:     assert unread_response.status_code == status.HTTP_200_OK
    1:     assert unread_response.json()["data"]["unread_count"] >= 1
       
       
    1: async def test_test_notification_creates_new_notification(async_client, user_auth_headers) -> None:
    1:     create_response = await async_client.post(f"{settings.api.prefix}{settings.api.v1.prefix}/notifications/test", headers=user_auth_headers)
    1:     assert create_response.status_code == status.HTTP_200_OK
    1:     assert create_response.json()["data"]["message"] == "Test notification sent"
       
    1:     list_response = await async_client.get(f"{settings.api.prefix}{settings.api.v1.prefix}/notifications", headers=user_auth_headers)
    2:     assert any(item["type"] == "test" for item in list_response.json()["data"])
