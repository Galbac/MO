    1: async def test_admin_media_accepts_base64_png(async_client, admin_auth_headers) -> None:
    2:     response = await async_client.post(
    1:         f"{settings.api.prefix}{settings.api.v1.prefix}/admin/media/upload",
    1:         json={
    1:             "filename": "cover.png",
    1:             "content_type": "image/png",
    1:             "content_base64": "iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mP8/x8AAwMCAO+jk6sAAAAASUVORK5CYII=",
               },
    1:         headers=admin_auth_headers,
           )
    1:     assert response.status_code == status.HTTP_201_CREATED
    1:     assert response.json()["data"]["filename"] == "cover.png"
