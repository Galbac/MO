    1:             "entity_id": 2,
    1:             "notification_types": ["unknown_type"],
    1:             "channels": ["web"],
               },
    1:         headers=user_auth_headers,
           )
    1:     assert response.status_code == status.HTTP_422_UNPROCESSABLE_ENTITY
