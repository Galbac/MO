    1:     assert sitemap_payload['base_url'] == 'https://example.test'
    1:     assert sitemap_payload['url_count'] >= 9
   17:     assert any(url.endswith('/players/novak-djokovic') for url in sitemap_payload['urls'])
    1:     assert search_index_payload['total_documents'] >= 4
    3:     assert any(item['slug'] == 'novak-djokovic' for item in search_index_payload['players'])
