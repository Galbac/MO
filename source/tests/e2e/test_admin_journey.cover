    1: from fastapi import status
       
    1: from source.config.settings import settings
       
       
    1: async def test_admin_end_to_end_journey(async_client, admin_auth_headers) -> None:
    1:     dashboard_response = await async_client.get('/admin')
    1:     assert dashboard_response.status_code == status.HTTP_200_OK
       
    2:     create_news = await async_client.post(
    1:         f"{settings.api.prefix}{settings.api.v1.prefix}/admin/news",
    1:         headers=admin_auth_headers,
    1:         json={
    1:             'slug': 'e2e-admin-article',
    1:             'title': 'E2E admin article',
    1:             'subtitle': 'Published from journey',
    1:             'lead': 'Lead',
    1:             'content_html': '<p>Body</p>',
    1:             'status': 'draft',
    1:             'category_id': 1,
               },
           )
    1:     assert create_news.status_code == status.HTTP_200_OK
    1:     news_id = create_news.json()['data']['id']
       
    2:     publish_news = await async_client.post(
    1:         f"{settings.api.prefix}{settings.api.v1.prefix}/admin/news/{news_id}/publish",
    1:         headers=admin_auth_headers,
           )
    1:     assert publish_news.status_code == status.HTTP_200_OK
       
    1:     public_news = await async_client.get(f"{settings.api.prefix}{settings.api.v1.prefix}/news/e2e-admin-article")
    1:     assert public_news.status_code == status.HTTP_200_OK
    1:     assert public_news.json()['data']['status'] == 'published'
       
    2:     score_update = await async_client.patch(
    1:         f"{settings.api.prefix}{settings.api.v1.prefix}/admin/matches/2/score",
    1:         headers=admin_auth_headers,
    1:         json={'score_summary': '6-4 4-6 5-2', 'sets': []},
           )
    1:     assert score_update.status_code == status.HTTP_200_OK
       
    2:     finalize = await async_client.post(
    1:         f"{settings.api.prefix}{settings.api.v1.prefix}/admin/matches/2/finalize",
    1:         headers=admin_auth_headers,
           )
    1:     assert finalize.status_code == status.HTTP_200_OK
       
    1:     match_detail = await async_client.get(f"{settings.api.prefix}{settings.api.v1.prefix}/matches/2")
    1:     assert match_detail.status_code == status.HTTP_200_OK
    1:     assert match_detail.json()['data']['status'] == 'finished'
       
       
    1: async def test_editor_and_operator_journeys(async_client, editor_auth_headers, operator_auth_headers) -> None:
    1:     editor_news = await async_client.get(f"{settings.api.prefix}{settings.api.v1.prefix}/admin/news", headers=editor_auth_headers)
    1:     assert editor_news.status_code == status.HTTP_200_OK
       
    1:     editor_users = await async_client.get(f"{settings.api.prefix}{settings.api.v1.prefix}/admin/users", headers=editor_auth_headers)
    1:     assert editor_users.status_code == status.HTTP_403_FORBIDDEN
       
    2:     operator_matches = await async_client.patch(
    1:         f"{settings.api.prefix}{settings.api.v1.prefix}/admin/matches/2/score",
    1:         headers=operator_auth_headers,
    1:         json={"score_summary": "6-4 4-6 5-4", "sets": []},
           )
    1:     assert operator_matches.status_code == status.HTTP_200_OK
       
    1:     operator_news = await async_client.get(f"{settings.api.prefix}{settings.api.v1.prefix}/admin/news", headers=operator_auth_headers)
    1:     assert operator_news.status_code == status.HTTP_403_FORBIDDEN
