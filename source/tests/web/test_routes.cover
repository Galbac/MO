    1: from fastapi import status
       
       
    1: async def test_home_page_renders_html(async_client) -> None:
    1:     response = await async_client.get("/")
       
    1:     assert response.status_code == status.HTTP_200_OK
    1:     assert "text/html" in response.headers["content-type"]
    1:     assert "Makhachkala Open" in response.text
    1:     assert "Счета, новости и рейтинги" in response.text
       
       
    1: async def test_admin_dashboard_renders_html(async_client) -> None:
    1:     response = await async_client.get("/admin")
       
    1:     assert response.status_code == status.HTTP_200_OK
    1:     assert "text/html" in response.headers["content-type"]
    1:     assert "Админка" in response.text
    1:     assert "Панель" in response.text
       
       
